DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
OPENAI_API_KEY=

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Public HTTPS origin used by OAuth redirects
APP_URL=https://your-public-domain.example
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
PUBLISH_CRON_ENABLED=false

# Instagram and Facebook / Meta
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://your-public-domain.example/api/auth/instagram/callback
META_GRAPH_API_VERSION=v24.0

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-public-domain.example/api/auth/linkedin/callback
LINKEDIN_VERSION=202606

# X
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://your-public-domain.example/api/auth/x/callback

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-public-domain.example/api/auth/tiktok/callback
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# Google / YouTube
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-public-domain.example/api/auth/youtube/callback
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=22
YOUTUBE_MAX_UPLOAD_BYTES=100000000

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=https://your-public-domain.example/api/auth/threads/callback

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=https://your-public-domain.example/api/auth/pinterest/callback
